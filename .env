# package kamu butuh ini (jangan null)
cas_login_url=https://sso.upi.edu/cas/login
cas_logout_url=https://sso.upi.edu/cas/logout

cas_debug=false
cas_validate_cn=true
cas_session_name=CASAuth
cas_control_sessions=false
cas_proxy=false

# debug (opsional saat troubleshooting)
CAS_VERBOSE_ERRORS=true
CAS_LOG=laravel

# kalau kamu mau paksa selalu masuk dashboard setelah login
CAS_REDIRECT_PATH=
